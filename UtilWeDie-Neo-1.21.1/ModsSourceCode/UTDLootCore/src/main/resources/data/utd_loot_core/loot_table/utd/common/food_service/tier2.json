        {
          "type": "minecraft:item",
          "name": "firstpersonfoodeating:pack_food",
          "weight": 8,
          "functions": [
            {
              "function": "minecraft:set_custom_data",
              "tag": "{firstpersonfoodeating_profile:{food_id:\"firstpersonfoodeating:i_guantou_a\",use_duration_ticks:132,nutrition:8,saturation:0.5f,max_stack_size:16,flavor_messages:{mode:\"actionbar\",pick:\"random_weighted\",cooldown_ticks:0,groups:[{id:\"default\",weight:1,segments:[{at_ticks:0,text:\"没有你想的那么绵密丝滑\"},{at_ticks:34,text:\"反而因为是炼乳块\"},{at_ticks:62,text:\"奶香味浓的有些腻歪\"},{at_ticks:92,text:\"香甜的有些齁人\"},{at_ticks:118,text:\"不管怎么说\"},{at_ticks:140,text:\"总算是有点东西下肚了\"}]}]}},food_id:\"firstpersonfoodeating:i_guantou_a\"}"
            }
          ]
        },
        {
          "type": "minecraft:item",
          "name": "firstpersonfoodeating:pack_food",
          "weight": 8,
          "functions": [
            {
              "function": "minecraft:set_custom_data",
              "tag": "{firstpersonfoodeating_profile:{food_id:\"firstpersonfoodeating:i_guantou_b\",use_duration_ticks:132,nutrition:8,saturation:0.5f,max_stack_size:16,thirst:{delta:-3,water_delta:0,mode:\"always\"},flavor_messages:{mode:\"actionbar\",pick:\"random_weighted\",cooldown_ticks:0,groups:[{id:\"default\",weight:1,segments:[{at_ticks:0,text:\"压缩饼干\"},{at_ticks:20,text:\".....\"},{at_ticks:42,text:\"罐头\"},{at_ticks:58,text:\"有的吃就不错了\"},{at_ticks:84,text:\"很干\"},{at_ticks:100,text:\"很硬\"},{at_ticks:116,text:\"没有什么调味\"},{at_ticks:140,text:\"也干噎得慌\"},{at_ticks:162,text:\"不过幸好不是很让人口干舌燥\"},{at_ticks:200,text:\"费水\"}]}]}},food_id:\"firstpersonfoodeating:i_guantou_b\"}"
            }
          ]
        },
        {
          "type": "minecraft:item",
          "name": "firstpersonfoodeating:pack_food",
          "weight": 8,
          "functions": [
            {
              "function": "minecraft:set_custom_data",
              "tag": "{firstpersonfoodeating_profile:{food_id:\"firstpersonfoodeating:i_guantou_c\",use_duration_ticks:132,nutrition:12,saturation:0.4166666666666667f,max_stack_size:16,thirst:{delta:2,water_delta:0,mode:\"always\"},flavor_messages:{mode:\"actionbar\",pick:\"random_weighted\",cooldown_ticks:0,groups:[{id:\"default\",weight:1,segments:[{at_ticks:0,text:\"红烧肉！好扎实的分量\"},{at_ticks:32,text:\"但是肉真的好肥\"},{at_ticks:58,text:\"不行了\"},{at_ticks:76,text:\"给我吃腻歪到了\"},{at_ticks:102,text:\"太油太肥了\"},{at_ticks:124,text:\"或许用来炖汤是一个不错的选择\"}]}]}},food_id:\"firstpersonfoodeating:i_guantou_c\"}"
            }
          ]
        },
        {
          "type": "minecraft:item",
