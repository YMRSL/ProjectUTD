{
  "name": "table",
  "description": "Fence post with pressure plate or carpet on top — vanilla table",
  "anchor": [0, 0, 0],
  "blocks": [
    {
      "offset": [0, 0, 0],
      "match": {"namespace": "minecraft", "name_endswith": "_fence"}
    },
    {
      "offset": [0, 1, 0],
      "match": {"namespace": "minecraft", "name_contains": ["pressure_plate", "carpet"]}
    }
  ],
  "dd_replacement": "doomsday_decoration:table",
  "replacement_anchor_offset": [0, 0, 0],
  "clear_offsets": [[0, 1, 0]]
}
