{
  "name": "tlou_decay_surfaces",
  "description": "Replace clean stone, concrete, and wood surfaces with weathered, cracked, and worn variants. First layer of TLOU stylization.",
  "version": "1.0",
  "destructive": true,
  "targets": ["floor", "outer_wall", "inner_wall", "rooftop"],
  "only_safe_blocks": true,
  "rules": [
    {
      "match": {
        "block": ["minecraft:stone_bricks", "minecraft:chiseled_stone_bricks"],
        "surface": ["outer_wall", "inner_wall"]
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:cracked_stone_bricks", "weight": 0.45},
        {"block": "minecraft:mossy_stone_bricks",   "weight": 0.25},
        {"block": "minecraft:cobblestone",          "weight": 0.15},
        {"block": "minecraft:stone_bricks",         "weight": 0.15}
      ],
      "weight": 1.0,
      "noise": {"scale": 0.05, "threshold": 0.30}
    },
    {
      "match": {
        "block": ["minecraft:white_concrete", "minecraft:gray_concrete", "minecraft:light_gray_concrete"],
        "surface": ["outer_wall", "floor"]
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:smooth_stone",      "weight": 0.35},
        {"block": "minecraft:polished_andesite", "weight": 0.30},
        {"block": "minecraft:cobblestone",       "weight": 0.20},
        {"block": "minecraft:gravel",            "weight": 0.15}
      ],
      "weight": 0.85,
      "noise": {"scale": 0.06, "threshold": 0.35}
    },
    {
      "match": {
        "block": ["minecraft:oak_planks", "minecraft:spruce_planks", "minecraft:birch_planks"],
        "surface": ["floor", "inner_wall"]
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:spruce_planks", "weight": 0.50},
        {"block": "minecraft:dark_oak_planks","weight": 0.30},
        {"block": "minecraft:coarse_dirt",   "weight": 0.20}
      ],
      "weight": 0.60,
      "noise": {"scale": 0.07, "threshold": 0.40}
    },
    {
      "match": {
        "block": ["minecraft:glass", "minecraft:glass_pane", "minecraft:white_stained_glass_pane"],
        "surface": ["outer_wall", "inner_wall"]
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:air",       "weight": 0.55},
        {"block": "minecraft:glass_pane","weight": 0.45}
      ],
      "weight": 0.70,
      "noise": {"scale": 0.10, "threshold": 0.50}
    },
    {
      "match": {
        "block": ["minecraft:torch", "minecraft:wall_torch"],
        "surface": ["inner_wall", "outer_wall"]
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:air", "weight": 0.65},
        {"block": "minecraft:torch","weight": 0.35}
      ],
      "weight": 0.80
    }
  ]
}
