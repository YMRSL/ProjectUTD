{
  "name": "tlou_nature_reclaim",
  "description": "Add moss, vines, leaf intrusions, and root growth to outer walls and rooftops. Nature reclaiming the city.",
  "version": "1.0",
  "targets": ["outer_wall", "rooftop"],
  "only_safe_blocks": true,
  "rules": [
    {
      "match": {
        "block": ["minecraft:stone_bricks", "minecraft:cracked_stone_bricks", "minecraft:cobblestone"],
        "surface": "outer_wall"
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:mossy_stone_bricks",  "weight": 0.50},
        {"block": "minecraft:mossy_cobblestone",   "weight": 0.20},
        {"block": "minecraft:stone_bricks",        "weight": 0.30}
      ],
      "weight": 1.0,
      "noise": {"scale": 0.04, "threshold": 0.35}
    },
    {
      "match": {
        "surface": "outer_wall",
        "adjacent_air": true
      },
      "action": "place_adjacent",
      "place_block": "minecraft:vine",
      "direction": "air_side",
      "weight": 0.18,
      "noise": {"scale": 0.08, "threshold": 0.48}
    },
    {
      "match": {
        "surface": "rooftop"
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:moss_block",  "weight": 0.40},
        {"block": "minecraft:grass_block", "weight": 0.30},
        {"block": "minecraft:dirt",        "weight": 0.30}
      ],
      "weight": 0.65,
      "noise": {"scale": 0.06, "threshold": 0.42}
    },
    {
      "match": {
        "surface": "rooftop",
        "adjacent_air": true
      },
      "action": "place_adjacent",
      "place_block": "minecraft:oak_leaves",
      "direction": "above",
      "weight": 0.22,
      "noise": {"scale": 0.10, "threshold": 0.55}
    },
    {
      "match": {
        "surface": "floor",
        "block": ["minecraft:stone_bricks", "minecraft:cobblestone", "minecraft:smooth_stone"]
      },
      "action": "replace",
      "replace_with": [
        {"block": "minecraft:moss_carpet",  "weight": 0.15},
        {"block": "minecraft:grass_block",  "weight": 0.10},
        {"block": "minecraft:stone_bricks", "weight": 0.75}
      ],
      "weight": 0.20,
      "noise": {"scale": 0.09, "threshold": 0.60}
    }
  ]
}
